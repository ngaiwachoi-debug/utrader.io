# === uTrader / bifinexbot.com — Environment Variables ===
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- DATABASE ---
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- REDIS ---
# Local: redis://127.0.0.1:6379
# Upstash (production): rediss://default:TOKEN@HOST:6379
REDIS_URL="redis://127.0.0.1:6379"

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-secret"

# --- ADMIN ---
# Only this email can access /admin/* endpoints
ADMIN_EMAIL=admin@example.com

# --- NEXTAUTH (must match in root .env AND frontend/.env.local) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="generate-a-random-base64-string"
NEXTAUTH_URL="http://localhost:3000"

# --- STRIPE (use sk_test_ for dev, sk_live_ for production) ---
STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (from Dashboard → Products → Pricing)
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."
STRIPE_PRICE_AI_ULTRA_MONTHLY="price_..."
STRIPE_PRICE_AI_ULTRA_YEARLY="price_..."
STRIPE_PRICE_WHALES_MONTHLY="price_..."
STRIPE_PRICE_WHALES_YEARLY="price_..."

# --- ENCRYPTION (AES-256 key for API vault) ---
# Generate: python -c "import os; print(os.urandom(32).hex())"
# ENCRYPTION_KEY="your-hex-key"

# --- API ---
NEXT_PUBLIC_API_BASE="http://127.0.0.1:8000"

# --- CORS (comma-separated production frontend URLs) ---
# CORS_ORIGINS="https://bifinexbot.com,https://www.bifinexbot.com"

# --- CRON (secret for /api/cron/refresh-lending-stats) ---
# CRON_SECRET="your-cron-secret"

# === DEV ONLY (unset all of these in production!) ===
# ALLOW_DEV_CONNECT=1
# STRIPE_WEBHOOK_DEBUG=1
